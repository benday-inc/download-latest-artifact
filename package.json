{
  "name": "download-latest-artifact",
  "version": "3.0.0",
  "private": true,
  "description": "Download the latest artifact from a successful github workflow for a given branch",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "jest",
    "all": "npm run build && npm run format && npm run lint && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benday-inc/download-latest-artifact.git"
  },
  "keywords": [
    "actions",
    "node",
    "artifact",
    "download"
  ],
  "author": "Benjamin Day Consulting, Inc.",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "2.0.3",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "axios": "^1.15.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.0.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.0.0",
    "jest": "^30.0.0",
    "jest-circus": "^30.0.0",
    "js-yaml": "^4.2.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.3.2",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "undici": ">=6.24.0"
  }
}
